		<xpath>Defs/FactionColonies.WorldSettlementDef[comps]/comps</xpath>
		<value>
			<li Class="EmpireVOE.WorldObjectCompProperties_OutpostLinks" />
		</value>
	</Operation>

	<!-- ============================================================ -->
	<!-- Outpost comps — ensure comps node exists, then add entries    -->
	<!-- ============================================================ -->

	<!-- Outpost_Defensive -->
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/WorldObjectDef[defName="Outpost_Defensive"]/comps</xpath>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/WorldObjectDef[defName="Outpost_Defensive"]</xpath>
			<value><comps /></value>
		</nomatch>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/WorldObjectDef[defName="Outpost_Defensive"]/comps</xpath>
		<value>
			<li Class="EmpireVOE.WorldObjectCompProperties_EmpireOutpost" />
			<li Class="EmpireVOE.WorldObjectCompProperties_EmpireDefensive" />
		</value>
	</Operation>

	<!-- Outpost_Science -->
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/WorldObjectDef[defName="Outpost_Science"]/comps</xpath>
