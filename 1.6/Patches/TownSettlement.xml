		<xpath>Defs/WorldObjectDef[defName="Outpost_Artillery"]/comps</xpath>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/WorldObjectDef[defName="Outpost_Artillery"]</xpath>
