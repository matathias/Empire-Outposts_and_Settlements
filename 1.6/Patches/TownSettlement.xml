<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ============================================================ -->
	<!-- Settlement comps                                              -->
	<!-- ============================================================ -->

	<!-- Add WorldObjectComp_OutpostBonus to all Empire settlement defs that have a comps list -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/FactionColonies.WorldSettlementDef[comps]/comps</xpath>
		<value>
			<li Class="EmpireVOE.WorldObjectCompProperties_OutpostBonus" />
		</value>
	</Operation>

	<!-- Add WorldObjectComp_ScienceLink to all Empire settlement defs that have a comps list -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/FactionColonies.WorldSettlementDef[comps]/comps</xpath>
		<value>
			<li Class="EmpireVOE.WorldObjectCompProperties_ScienceLink" />
		</value>
	</Operation>

	<!-- Add WorldObjectComp_EncampmentBonus to all Empire settlement defs that have a comps list -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/FactionColonies.WorldSettlementDef[comps]/comps</xpath>
		<value>
			<li Class="EmpireVOE.WorldObjectCompProperties_EncampmentBonus" />
		</value>
	</Operation>

	<!-- Add WorldObjectComp_OutpostLinks to all Empire settlement defs that have a comps list -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/FactionColonies.WorldSettlementDef[comps]/comps</xpath>
		<value>
			<li Class="EmpireVOE.WorldObjectCompProperties_OutpostLinks" />
		</value>
	</Operation>

	<!-- ============================================================ -->
	<!-- Outpost comps                                                 -->
	<!-- ============================================================ -->

	<!-- Add the core Empire integration comp to ALL outposts via their shared abstract parent
	     (VEF's OutpostBase). Children inherit and merge the parent's comps list, so this single
	     patch covers every outpost type - including ones from other VEF-based outpost mods -
	     instead of enumerating each defName. -->
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/WorldObjectDef[@Name="OutpostBase"]/comps</xpath>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/WorldObjectDef[@Name="OutpostBase"]</xpath>
			<value><comps /></value>
		</nomatch>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/WorldObjectDef[@Name="OutpostBase"]/comps</xpath>
		<value>
			<li Class="EmpireVOE.WorldObjectCompProperties_EmpireOutpost" />
		</value>
	</Operation>

	<Operation Class="PatchOperationConditional">
		<xpath>Defs/WorldObjectDef[defName="Outpost_Defensive"]/comps</xpath>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/WorldObjectDef[defName="Outpost_Defensive"]</xpath>
			<value><comps /></value>
		</nomatch>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/WorldObjectDef[defName="Outpost_Defensive"]/comps</xpath>
		<value>
			<li Class="EmpireVOE.WorldObjectCompProperties_EmpireDefensive" />
		</value>
	</Operation>

	<!-- ============================================================ -->
	<!-- Town description update                                       -->
	<!-- ============================================================ -->

	<!-- Update VOE Town outpost description: hospitality/recruitment flavor (folded in from
	     "VOE Towns Count Outposts") plus the Empire conversion note. -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/WorldObjectDef[defName="Outpost_Town"]/description</xpath>
		<value>
			<description>Places a temporary, autonomously-led town that is designed to provide hospitality to travelers and traders alike. Should a visitor find their lodging amicable they will be invited to join the town as a resident permanently. Can be converted into an Empire settlement.</description>
		</value>
	</Operation>

</Patch>
